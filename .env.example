# ─────────────────────────────────────────────────────────────
# AccessGuard AI — Environment Configuration
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Slack ──────────────────────────────────────────────────
# From https://api.slack.com/apps → your app.
# Socket Mode is used so you don't need a public URL for the demo.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# ── LLM (optional) ─────────────────────────────────────────
# Optional. If omitted, AccessGuard falls back to a fully
# deterministic local reasoning engine so the demo always works.
#
# Option A — OpenAI:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
#
# Option B — OpenRouter (takes precedence if set). Uses the OpenAI-compatible
# Chat Completions API. Model must be a full OpenRouter id, e.g.
# "openai/gpt-4o-mini", "anthropic/claude-3.5-sonnet", "google/gemini-flash-1.5".
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Runtime ────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
ACCESSGUARD_DB_PATH=./database/accessguard.db
LOG_LEVEL=info
NODE_ENV=development
